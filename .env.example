# ── AI Automation Bot — environment ──
# All values are SERVER-ONLY. Never commit a real .env.

# OpenAI (optional): without a usable key the bot runs in local-demo mode
# (scripted replies). Set in production for real AI responses.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development   # set to "production" on deploy (enforces ADMIN_TOKEN)

# Admin dashboard auth (REQUIRED in production).
# /api/admin/* exposes customer PII (names, emails, phones) — the server
# refuses to start in production without a strong ADMIN_TOKEN (>= 16 chars).
ADMIN_TOKEN=

# CORS: comma-separated origin allowlist for cross-origin API calls.
# Leave empty for same-origin only (recommended; the UI is served by this server).
ALLOWED_ORIGINS=

# Rate limiting (per IP, fixed window). Defaults shown.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60          # all /api routes
CHAT_RATE_LIMIT_MAX=20     # stricter limit on /api/chat (controls OpenAI cost)

# Set to 1 if behind a reverse proxy in non-production (prod trusts proxy by default).
TRUST_PROXY=

# Persistent data directory (messages.json, leads.json).
# IMPORTANT: on platforms with ephemeral disks, point this at a mounted volume,
# e.g. DATA_DIR=/data, so chat history and leads survive restarts.
DATA_DIR=data
